# Development environment configuration
# Copy this file to .env and configure if needed
# NEVER commit .env — it is gitignored

# (Optional) Path to local pursuits directory during development
# In production, users configure this via the Setup Wizard
# Leave empty to rely on per-machine config in %APPDATA%/ResumeGenerator/config.json
LOCAL_PURSUITS_ROOT=

# (Optional) Allow paths outside the repository
# Set to true if your data directory is outside the repo root
ALLOW_EXTERNAL_PATHS=false
