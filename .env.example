# Default safety: block paths outside this repository.
ALLOW_EXTERNAL_PATHS=false

# Local-first defaults (all are relative to repo root when not absolute).
LOCAL_DATA_ROOT=./data
TEMPLATES_DIR=./templates
LOCAL_OUTPUTS_ROOT=./outputs
LOCAL_PURSUITS_ROOT=./pursuits_local
SELECTIONS_PATH=./data/selections.yaml
WORKBOOK_PATH=./data/extraction IPR.xlsx
YAML_TEMPLATE_PATH=./data/selections.template.yaml
MASTER_REFERENCES_PATH=./data/Client References-2026.xlsx

# Shared workbook mode (set ALLOW_EXTERNAL_PATHS=true before using these).
# Optional one-root mode to keep everything contained in one Staff Resumes subfolder:
# STAFF_RESUMES_TOOL_ROOT=C:\Users\<you>\OneDrive - Blackline Consulting\Pursuits - Documents\_Proposal Objects\Staff Resumes\proposal_tool_runtime
# If set, defaults become:
# - PERSON_WORKBOOKS_DIR=%STAFF_RESUMES_TOOL_ROOT%\person_workbooks
# - GLOBAL_WORKBOOK_DIR=%STAFF_RESUMES_TOOL_ROOT%\_generated
#
# PERSON_WORKBOOKS_DIR=C:\Users\<you>\OneDrive - Blackline Consulting\Pursuits - Documents\_Proposal Objects\Staff Resumes\person_workbooks
# GLOBAL_WORKBOOK_DIR=C:\Users\<you>\OneDrive - Blackline Consulting\Pursuits - Documents\_Proposal Objects\Staff Resumes\_generated
GLOBAL_WORKBOOK_BASENAME=global_resume_data
GLOBAL_WORKBOOK_KEEP_COUNT=2
REFRESH_GLOBAL_WORKBOOK_ON_RUN=false
