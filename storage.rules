rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Generated resume outputs — authenticated users can read their own job outputs.
    // Only the backend service account writes (via Admin SDK, bypasses rules).
    match /outputs/{jobId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // backend only
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
