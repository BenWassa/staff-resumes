rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuth() && userDoc().data.role == "admin";
    }

    // Role assigned on sign-up is "staff"
    function isStaff() {
      return isAuth() && userDoc().data.role == "staff";
    }

    // Authorised email whitelist — keep in sync with web/src/allowedEmails.js
    function isAllowedEmail() {
      let e = request.auth.token.email.lower();
      return e in [
        "graham.pressey@blacklineconsulting.ca",
        "ian.shelley@blacklineconsulting.ca",
        "abdel.al-sharif@blacklineconsulting.ca",
        "anum.nasir@blacklineconsulting.ca",
        "yash.melwani@blacklineconsulting.ca",
        "nikhil.konduru@blacklineconsulting.ca",
        "john.connolly@blacklineconsulting.ca",
        "michelle.tam@blacklineconsulting.ca",
        "rehan.setna@blacklineconsulting.ca",
        "laura.devenny@blacklineconsulting.ca",
        "ben.haddon@blacklineconsulting.ca"
      ];
    }

    // ── /users ──────────────────────────────────────────────────────────────
    // A user may create their own doc on first sign-in if their email is
    // whitelisted and they are not self-assigning admin.
    // Only admins can update user docs (e.g. to set staff_id or change role).
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role != "admin"
        && isAllowedEmail();
      allow update, delete: if isAdmin();
    }

    // ── /staff ──────────────────────────────────────────────────────────────
    // Any authenticated user can read staff profiles.
    // A staff member can write their own linked profile; admins can write any.
    match /staff/{staffId} {
      allow read: if isAuth();
      allow write: if isAdmin()
        || (isStaff() && userDoc().data.staff_id == staffId);

      match /education/{eduId} {
        allow read: if isAuth();
        allow write: if isAdmin()
          || (isStaff() && userDoc().data.staff_id == staffId);
      }

      match /projects/{projectKey} {
        allow read: if isAuth();
        allow write: if isAdmin()
          || (isStaff() && userDoc().data.staff_id == staffId);
      }
    }

    // ── /pursuits ────────────────────────────────────────────────────────────
    match /pursuits/{pursuitId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── /sessions ────────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read, write: if isAuth();
    }

    // ── /jobs ────────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isAuth()
        && resource.data.created_by == request.auth.uid;
      allow write: if false; // backend only (service account bypasses rules)
    }
  }
}
