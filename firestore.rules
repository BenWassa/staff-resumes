rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: fetch the calling user's /users doc (for role check)
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuth() && userDoc().data.role == "admin";
    }

    function isMember() {
      return isAuth() && userDoc().data.role == "member";
    }

    // Authorised email whitelist — keep in sync with web/src/allowedEmails.js
    function isAllowedEmail() {
      let e = request.auth.token.email.lower();
      return e in [
        "graham.pressey@blacklineconsulting.ca",
        "ian.shelley@blacklineconsulting.ca",
        "abdel.al-sharif@blacklineconsulting.ca",
        "anum.nasir@blacklineconsulting.ca",
        "yash.melwani@blacklineconsulting.ca",
        "nikhil.konduru@blacklineconsulting.ca",
        "john.connolly@blacklineconsulting.ca",
        "michelle.tam@blacklineconsulting.ca",
        "rehan.setna@blacklineconsulting.ca",
        "laura.devenny@blacklineconsulting.ca",
        "ben.haddon@blacklineconsulting.ca"
      ];
    }

    // ── /users ──────────────────────────────────────────────────────────────
    // Users can read their own doc.
    // A user may create their own doc only if their email is on the whitelist
    // and they are not self-assigning admin. Admins can write any user doc.
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role != "admin"
        && isAllowedEmail();
      allow update, delete: if isAdmin();
    }

    // ── /staff ──────────────────────────────────────────────────────────────
    // Any authenticated user can read staff profiles.
    // A member can write their own linked staff doc; admins can write any.
    match /staff/{staffId} {
      allow read: if isAuth();
      allow write: if isAdmin()
        || (isMember() && userDoc().data.staff_id == staffId);

      // Education subcollection — same rules as parent
      match /education/{eduId} {
        allow read: if isAuth();
        allow write: if isAdmin()
          || (isMember() && userDoc().data.staff_id == staffId);
      }

      // Projects subcollection — same rules as parent
      match /projects/{projectKey} {
        allow read: if isAuth();
        allow write: if isAdmin()
          || (isMember() && userDoc().data.staff_id == staffId);
      }
    }

    // ── /pursuits ────────────────────────────────────────────────────────────
    // All authenticated users read; only admins create/update.
    match /pursuits/{pursuitId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── /sessions ────────────────────────────────────────────────────────────
    // All authenticated users can read and write sessions.
    match /sessions/{sessionId} {
      allow read, write: if isAuth();
    }

    // ── /jobs ────────────────────────────────────────────────────────────────
    // Users can read their own jobs. Only the backend service account writes.
    match /jobs/{jobId} {
      allow read: if isAuth()
        && resource.data.created_by == request.auth.uid;
      allow write: if false; // backend only (service account bypasses rules)
    }
  }
}
