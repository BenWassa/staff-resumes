{
  "name": "resume-generator-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "powershell -Command \"Get-Process python -ErrorAction SilentlyContinue | Where-Object { $_.CommandLine -like '*uvicorn web.main:app*--port 8002*' } | Stop-Process -Force; exit 0\"",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "python -m uvicorn web.main:app --app-dir .. --reload --port 8002",
    "dev:client": "vite --port 5174",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  }
}
