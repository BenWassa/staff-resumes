{
  "name": "resume-generator-ui",
  "private": true,
  "version": "0.1.0",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "predev": "powershell -Command \"Get-Process python -ErrorAction SilentlyContinue | Where-Object { $_.CommandLine -like '*uvicorn web.main:app*--port 8002*' } | Stop-Process -Force; exit 0\"",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "python -m uvicorn web.main:app --app-dir .. --reload --port 8002",
    "dev:client": "vite --port 5174",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev:api\" \"wait-on http://localhost:8002 && electron .\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.blackline.resumegenerator",
    "productName": "Resume Generator",
    "icon": "../public/BLC_nobg.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer",
      "electron-main.js",
      "preload.js",
      "node_modules",
      "package.json",
      "main.py",
      "requirements.txt"
    ],
    "win": {
      "icon": "../public/BLC_nobg.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "../public/BLC_nobg.ico",
      "uninstallerIcon": "../public/BLC_nobg.ico"
    },
    "extraResources": [
      {
        "from": "../public/BLC_nobg.ico",
        "to": "assets/BLC_nobg.ico"
      },
      {
        "from": "main.py",
        "to": "python/web/main.py"
      },
      {
        "from": "api",
        "to": "python/web/api"
      },
      {
        "from": "../src",
        "to": "python/src"
      },
      {
        "from": "../data",
        "to": "python/data"
      },
      {
        "from": "../templates",
        "to": "python/templates"
      }
    ]
  }
}
